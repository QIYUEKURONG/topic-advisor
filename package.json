{
  "name": "topic-advisor",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "AI-powered content creation tool — crawl trending topics, AI rewrite, multi-platform publish",
  "author": "Topic Advisor Team",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"pnpm --filter server dev\" \"pnpm --filter web dev\"",
    "build": "pnpm --filter web build && pnpm --filter server build",
    "start": "pnpm --filter server start",
    "bundle:server": "node scripts/bundle-server.mjs",
    "electron:dev": "pnpm build && pnpm bundle:server && electron .",
    "predist": "rm -rf release",
    "dist:mac": "pnpm predist && pnpm build && pnpm bundle:server && electron-builder --mac",
    "dist:win": "pnpm predist && pnpm build && pnpm bundle:server && electron-builder --win",
    "dist:all": "pnpm predist && pnpm build && pnpm bundle:server && electron-builder --mac --win"
  },
  "build": {
    "appId": "com.topic-advisor.app",
    "productName": "Topic Advisor",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "server/bundle",
        "to": "server/bundle"
      },
      {
        "from": "web/dist",
        "to": "web/dist"
      },
      {
        "from": "server/node_modules_electron",
        "to": "server/node_modules"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "typescript": "^5.8.3"
  }
}
